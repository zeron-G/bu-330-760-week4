# Backend selection:
#   auto   -> prefer Codex OAuth, then OPENAI_API_KEY, then GOOGLE_API_KEY
#   codex  -> force ~/.codex/auth.json
#   openai -> force OPENAI_API_KEY
#   google -> force GOOGLE_API_KEY
MODEL_PROVIDER=auto

# Model choices:
CODEX_MODEL=gpt-5.4-mini
OPENAI_MODEL=gpt-4.1-mini
GOOGLE_MODEL=gemini-2.5-flash

# API keys:
OPENAI_API_KEY=your-openai-key-here
GOOGLE_API_KEY=your-google-key-here
